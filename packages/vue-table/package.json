{
  "name": "@ioi-dev/vue-table",
  "version": "0.1.4",
  "description": "IOI Vue Table package",
  "author": "Rawand Hawez",
  "contributors": [
    "Rawand Hawez"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rawand-Hawez/ioi-vue-table.git"
  },
  "homepage": "https://github.com/Rawand-Hawez/ioi-vue-table#readme",
  "bugs": {
    "url": "https://github.com/Rawand-Hawez/ioi-vue-table/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/ioi-vue-table.cjs",
  "module": "./dist/ioi-vue-table.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ioi-vue-table.js",
      "require": "./dist/ioi-vue-table.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "node ../../node_modules/vite/bin/vite.js --config vite.config.ts",
    "build": "node ../../node_modules/vite/bin/vite.js build --config vite.config.ts && node ../../node_modules/vue-tsc/bin/vue-tsc.js --declaration --emitDeclarationOnly --outDir dist -p tsconfig.build.json",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "typecheck": "node ../../node_modules/vue-tsc/bin/vue-tsc.js --noEmit -p tsconfig.json",
    "lint": "node ../../node_modules/eslint/bin/eslint.js \"src/**/*.{ts,vue}\" \"test/**/*.ts\""
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vitest": "^2.1.8",
    "vue": "^3.4.38",
    "vue-tsc": "^2.2.0"
  }
}
